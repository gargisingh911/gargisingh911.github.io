function scoreAllMeals(ans){
  var pool=ALL_MEALS.filter(function(m){return m.type!=="cheat"&&m.type!=="experiment";});
  return pool.map(function(m){
    var sc=Math.random()*0.4;
    var mood=ans.mood||"",wo=ans.workout||"",goal=ans.goal||"",diet=ans.diet||"",time=ans.time||"",carry=ans.carrying||"",flavour=ans.flavour||"";
    if(mood==="Party mode, feed me well"&&m.cal>500)sc+=2;
    if(mood==="Lazy, minimum effort"&&m.tsec<=900)sc+=3;
    if(mood==="Tired and need comfort"&&m.tags.indexOf("comfort")>-1)sc+=3;
    if(mood==="Healthy and motivated"&&(m.tags.indexOf("light")>-1||m.tags.indexOf("protein")>-1))sc+=2;
    if(mood==="Treating myself"&&(m.tags.indexOf("fun")>-1||m.cal>500))sc+=2;
    if((wo==="Yes, protein please"||goal==="High protein")&&m.tags.indexOf("protein")>-1)sc+=3;
    if(wo==="Yes, carbs to refuel"&&(m.name.toLowerCase().indexOf("rice")>-1||m.name.toLowerCase().indexOf("pasta")>-1))sc+=2;
    if((wo==="No, keeping it lighter"||goal==="Low calorie")&&m.cal<450)sc+=2;
    if((wo==="No, I want something indulgent")&&m.cal>520)sc+=2;
    if(goal==="Something very quick"&&m.tsec<=600)sc+=3;
    if(goal==="Cheat meal energy"&&m.tags.indexOf("fun")>-1)sc+=2;
    if(diet==="Full vegetarian"&&m.tags.indexOf("chicken")>-1)sc-=10;
    if(diet==="Full vegetarian"&&m.tags.indexOf("vegetarian")>-1)sc+=2;
    if(diet==="Eggs are fine"&&m.tags.indexOf("chicken")>-1)sc-=5;
    if(time==="Under 10 min"&&m.tsec<=600)sc+=3;
    if(time==="10-20 min"&&m.tsec<=1200)sc+=2;
    if(time==="20-30 min"&&m.tsec<=1800)sc+=1;
    if(carry==="Carrying as tiffin"&&!m.tiffin)sc-=4;
    if(carry==="Carrying as tiffin"&&m.tiffin)sc+=2;
    if(carry==="Eating at home"&&!m.tiffin)sc+=1;
    if(flavour==="Warm and spicy"&&m.tags.indexOf("spicy")>-1)sc+=2;
    if(flavour==="Fresh and light"&&m.tags.indexOf("light")>-1)sc+=2;
    if(flavour==="Rich and comforting"&&m.tags.indexOf("comfort")>-1)sc+=2;
    if(flavour==="Whatever is easiest"&&m.tsec<=900)sc+=2;
    return{m:m,sc:sc};
  }).sort(function(a,b){return b.sc-a.sc;}).slice(0,3).map(function(x){return x.m;});
}

function matchFreeText(txt){
  txt=txt.toLowerCase();
  var pool=ALL_MEALS.filter(function(m){return m.type!=="cheat"&&m.type!=="experiment";});
  var kw={"quick":function(m){return m.tsec<=900;},"fast":function(m){return m.tsec<=600;},"egg":function(m){return m.tags.indexOf("eggs")>-1;},"rice":function(m){return m.name.toLowerCase().indexOf("rice")>-1;},"pasta":function(m){return m.name.toLowerCase().indexOf("pasta")>-1;},"dal":function(m){return m.name.toLowerCase().indexOf("dal")>-1||m.name.toLowerCase().indexOf("lentil")>-1;},"spicy":function(m){return m.tags.indexOf("spicy")>-1;},"veg":function(m){return m.tags.indexOf("vegetarian")>-1;},"protein":function(m){return m.tags.indexOf("protein")>-1;},"light":function(m){return m.cal<450;},"comfort":function(m){return m.tags.indexOf("comfort")>-1;},"tiffin":function(m){return m.tiffin;},"chicken":function(m){return m.tags.indexOf("chicken")>-1;},"toast":function(m){return m.name.toLowerCase().indexOf("toast")>-1;},"soup":function(m){return m.name.toLowerCase().indexOf("soup")>-1;},"noodle":function(m){return m.name.toLowerCase().indexOf("noodle")>-1;}};
  var scored=pool.map(function(m){var sc=Math.random()*0.3;Object.keys(kw).forEach(function(k){if(txt.indexOf(k)>-1&&kw[k](m))sc+=2;});return{m:m,sc:sc};}).sort(function(a,b){return b.sc-a.sc;});
  return scored.slice(0,3).map(function(x){return x.m;});
}

