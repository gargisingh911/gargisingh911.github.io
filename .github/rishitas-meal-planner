var DEFAULT_ILLUS = '<svg viewBox="0 0 300 160" xmlns="http://www.w3.org/2000/svg">\n  <rect width="300" height="160" fill="#F5EDD8"/>\n  <ellipse cx="150" cy="105" rx="80" ry="38" fill="#E0CCA8" stroke="#C8B48A" stroke-width="1.5"/>\n  <ellipse cx="150" cy="95" rx="76" ry="35" fill="#D4882A" opacity="0.8"/>\n  <circle cx="135" cy="90" r="8" fill="#C87030" opacity="0.6"/>\n  <circle cx="155" cy="85" r="6" fill="#B86020" opacity="0.55"/>\n  <circle cx="165" cy="95" r="7" fill="#C87030" opacity="0.5"/>\n  <text x="100" y="145" font-family="Lora,serif" font-size="10" fill="#7A6548" font-style="italic">from Rishita\'s kitchen</text>\n</svg>';

function renderMeals(){
  var grid=document.getElementById("meals-grid");
  var dm=ALL_MEALS.filter(function(m){
    if(m.day!==currentDay||m.type==="cheat"||m.type==="experiment")return false;
    if(mealTypeFilter==="tiffin"&&!m.tiffin)return false;
    if(mealTypeFilter==="home"&&m.tiffin)return false;
    return true;
  });
  grid.innerHTML=dm.map(function(m){
    var idx=ALL_MEALS.indexOf(m),icon=m.type==="lunch"?"&#9728;":"&#127769;",label=m.type==="lunch"?"Lunch":"Dinner";
    var illus=MEAL_ILLUS[m.name]||DEFAULT_ILLUS;
    return'<div class="mcard" data-idx="'+idx+'">'+
      '<div class="mcard-illus">'+illus+'</div>'+
      '<div class="mcard-top"><span class="mtag t'+m.type[0]+'">'+icon+' '+label+'</span>'+(m.tiffin?'<span class="tiffin-ok">tiffin</span>':'')+'<h3>'+m.name+'</h3><p class="mdesc">'+m.desc+'</p></div>'+
      '<div class="mcard-ft"><div class="chips"><span class="chip">&#9201; '+m.time+'</span><span class="chip">~'+(m.cal*PORTIONS)+' kcal</span></div><button class="ebtn">open &#8594;</button></div></div>';
  }).join("");
  if(!dm.length)grid.innerHTML='<p style="grid-column:1/-1;font-size:13px;color:var(--muted);font-style:italic;text-align:center;padding:1rem">No meals match this filter.</p>';
  grid.querySelectorAll(".mcard").forEach(function(card){card.addEventListener("click",function(){openModal(parseInt(card.getAttribute("data-idx")));});});
}

function renderOverview(){
  var grid=document.getElementById("ov-grid");
  var labels=["Mon","Tue","Wed","Thu","Fri","Sat","Sun"];
  grid.innerHTML=days.map(function(d,i){return'<div class="ovc'+(i===0?" active":"")+'" data-i="'+i+'"><div class="ovlbl">'+labels[i]+'</div><div class="ovname">'+d.name.slice(0,3)+'</div></div>';}).join("");
  grid.querySelectorAll(".ovc").forEach(function(c){c.addEventListener("click",function(){showDay(parseInt(c.getAttribute("data-i")));});});
}

var activeFilters=[];
var ALL_FILTERS=["vegetarian","eggs","chicken","quick","protein","light","spicy","comfort","tiffin-ok","one-pot","no-cook"];
function renderBooklet(){
  var fbBar=document.getElementById("filter-bar");
  fbBar.innerHTML=ALL_FILTERS.map(function(f){return'<button class="fbtn'+(activeFilters.indexOf(f)>-1?" on":"")+'" data-f="'+f+'">'+f+'</button>';}).join("");
  fbBar.querySelectorAll(".fbtn").forEach(function(btn){btn.addEventListener("click",function(){var f=btn.getAttribute("data-f");var i=activeFilters.indexOf(f);if(i>-1)activeFilters.splice(i,1);else activeFilters.push(f);renderBooklet();});});
  var pool=ALL_MEALS.filter(function(m){return m.type!=="cheat"&&m.type!=="experiment";});
  if(activeFilters.length){pool=pool.filter(function(m){return activeFilters.every(function(f){if(f==="tiffin-ok")return m.tiffin;return m.tags.indexOf(f)>-1;});});}
  var grid=document.getElementById("booklet-grid");
  grid.innerHTML=pool.map(function(m){
    var idx=ALL_MEALS.indexOf(m),dayLabel=m.day===-1?"Any day":days[m.day]?days[m.day].name:m.type;
    return'<div class="bcard" data-idx="'+idx+'"><div class="bcard-day">'+dayLabel+(m.tiffin?'<span class="tiffin-ok" style="margin-left:4px">tiffin</span>':'')+'</div><h4>'+m.name+'</h4><p>'+m.desc+'</p><div class="bcard-tags">'+m.tags.slice(0,3).map(function(t){return'<span class="bt">'+t+'</span>';}).join("")+'<span class="bt">'+m.time+'</span></div></div>';
  }).join("");
  if(!pool.length)grid.innerHTML='<p style="grid-column:1/-1;font-size:13px;color:var(--muted);font-style:italic;text-align:center;padding:2rem">No recipes match those filters.</p>';
  grid.querySelectorAll(".bcard").forEach(function(card){card.addEventListener("click",function(){openModal(parseInt(card.getAttribute("data-idx")));});});
}

function renderDesserts(){
  var grid=document.getElementById("desserts-grid");
  grid.innerHTML=DESSERTS.map(function(d,i){return'<div class="dcard" data-i="'+i+'"><div class="dcard-icon">'+d.icon+'</div><h4>'+d.name+'</h4><p>'+d.desc+'</p><div class="dcard-ft"><span class="bt">'+d.time+'</span><span class="bt">~'+d.cal+' kcal</span></div></div>';}).join("");
  grid.querySelectorAll(".dcard").forEach(function(card){card.addEventListener("click",function(){var d=DESSERTS[parseInt(card.getAttribute("data-i"))];openDessertModal(d);});});
}

function openDessertModal(d){
  document.getElementById("m-tag").textContent="Sweet Things \u00b7 Quick Dessert";
  document.getElementById("m-title").textContent=d.name;
  var il=d.ingr.map(function(i){return'<li>'+i+'</li>';}).join("");
  var sl=d.steps.map(function(s,i){return'<div class="step"><div class="snum">'+(i+1)+'</div><span>'+s+'</span></div>';}).join("");
  document.getElementById("m-body").innerHTML='<div class="msec"><h4>Ingredients</h4><ul class="ilist">'+il+'</ul></div><div class="msec"><h4>Method</h4><div class="slist">'+sl+'</div></div><div class="msec"><h4>Note</h4><div class="ptip">'+d.tip+'</div></div>';
  document.getElementById("modal").classList.add("open");
  document.body.style.overflow="hidden";
}

function openModal(idx){
  clearInterval(tIv);tRun=false;nudgeShown=false;
  var m=ALL_MEALS[idx];
  var typeLabel=m.type==="lunch"?"Lunch":m.type==="cheat"?"Cheat Night":m.type==="experiment"?"Sunday Experiment":"Dinner";
  document.getElementById("m-tag").textContent=typeLabel+(m.day>=0?" \u00b7 "+days[m.day].name:"");
  document.getElementById("m-title").textContent=m.name;
  var pNote='<div class="portion-note">&#127860; Scaled for <strong>'+PORTIONS+'</strong> portion'+(PORTIONS>1?"s":"")+'</div>';
  var il=m.ingr.map(function(i){var q=i.unit?fmtQty(i.qty,PORTIONS)+" "+i.unit:fmtQty(i.qty,PORTIONS);return'<li>'+q+' '+i.n+(i.r?'<span class="reused-tag"> (reused)</span>':'')+'</li>';}).join("");
  var sl=m.steps.map(function(s,i){return'<div class="step"><div class="snum">'+(i+1)+'</div><span>'+s+'</span></div>';}).join("");
  document.getElementById("m-body").innerHTML=pNote+'<div class="msec"><h4>Ingredients</h4><ul class="ilist">'+il+'</ul></div><div class="msec"><h4>Method</h4><div class="slist">'+sl+'</div></div><div class="msec"><h4>Prep note</h4><div class="ptip">'+m.tip+'</div></div>'+(m.tsec>0?buildGameHTML(m.tsec):'')+buildPhotoSection();
  document.getElementById("modal").classList.add("open");
  document.body.style.overflow="hidden";
  if(m.tsec>0)attachGameListeners(m.tsec);
  attachPhotoListeners(m.name);
}

function closeModal(){clearInterval(tIv);tRun=false;document.getElementById("modal").classList.remove("open");document.body.style.overflow="";}

function renderGrocery(){
  var grid=document.getElementById("groc-grid");
  grid.innerHTML=Object.keys(GROCERY).map(function(cat){
    var items=GROCERY[cat].map(function(item){var q=item.unit?fmtQty(item.qty,PORTIONS)+" "+item.unit:fmtQty(item.qty,PORTIONS);return'<div class="gi"><div class="gchk">&#10003;</div><span class="qty-s">'+q+'</span><span>'+item.n+'</span>'+(item.r?'<div class="rdot"></div>':'')+'</div>';}).join("");
    return'<div class="gcat"><h4>'+cat+'</h4>'+items+'</div>';
  }).join("");
  grid.querySelectorAll(".gi").forEach(function(el){el.addEventListener("click",function(){el.classList.toggle("ck");});});
}

var jrnlEntries=[],jrnlPhotoData=null;
document.getElementById("jrnl-photo").addEventListener("change",function(){var f=this.files[0];if(!f)return;var reader=new FileReader();reader.onload=function(e){jrnlPhotoData=e.target.result;document.getElementById("jrnl-photo-name").textContent=f.name;};reader.readAsDataURL(f);});
document.getElementById("jrnl-save").addEventListener("click",function(){var t=document.getElementById("jrnl-title").value.trim(),b=document.getElementById("jrnl-body").value.trim();if(!t&&!b){alert("Write something first!");return;}var entry={title:t||"Untitled",body:b,photo:jrnlPhotoData,date:new Date().toLocaleDateString("en-AU",{weekday:"short",day:"numeric",month:"short",year:"numeric"})};jrnlEntries.unshift(entry);document.getElementById("jrnl-title").value="";document.getElementById("jrnl-body").value="";document.getElementById("jrnl-photo-name").textContent="";jrnlPhotoData=null;renderJournal();});
document.getElementById("share-btn").addEventListener("click",function(){var email=document.getElementById("share-email").value.trim();if(!email){alert("Enter an email address");return;}var latest=jrnlEntries[0];if(!latest){alert("Save a journal entry first!");return;}var sub=encodeURIComponent("Kitchen journal: "+latest.title);var body=encodeURIComponent(latest.title+"\n"+latest.date+"\n\n"+latest.body);window.location.href="mailto:"+email+"?subject="+sub+"&body="+body;});
function renderJournal(){var el=document.getElementById("jrnl-entries");el.innerHTML=jrnlEntries.map(function(e,i){return'<div class="jentry"><div class="jentry-date">'+e.date+'</div><div class="jentry-title">'+e.title+'</div><div class="jentry-body">'+e.body+'</div>'+(e.photo?'<img class="jentry-photo" src="'+e.photo+'" alt="food photo">':'')+'<button class="jentry-del" data-i="'+i+'">&#10005;</button></div>';}).join("");el.querySelectorAll(".jentry-del").forEach(function(btn){btn.addEventListener("click",function(){jrnlEntries.splice(parseInt(btn.getAttribute("data-i")),1);renderJournal();});});}

document.querySelectorAll(".nday").forEach(function(btn){btn.addEventListener("click",function(){showDay(parseInt(btn.getAttribute("data-day")));});});
function switchView(active){["meals","booklet","desserts","grocery","journal"].forEach(function(id){var el=document.getElementById(id+"-view");if(!el)return;var show=id===active;el.style.display=show?"block":"none";if(el.classList.contains("groc-sec")||el.classList.contains("vis")){if(show)el.classList.add("vis");else el.classList.remove("vis");}});document.querySelectorAll(".npill").forEach(function(p){p.classList.remove("af");});}
document.getElementById("btn-meals").addEventListener("click",function(){switchView("meals");this.classList.add("af");});
document.getElementById("btn-booklet").addEventListener("click",function(){switchView("booklet");this.classList.add("af");renderBooklet();});
document.getElementById("btn-desserts").addEventListener("click",function(){switchView("desserts");this.classList.add("af");renderDesserts();});
document.getElementById("btn-grocery").addEventListener("click",function(){switchView("grocery");this.classList.add("af");renderGrocery();});
document.getElementById("btn-journal").addEventListener("click",function(){switchView("journal");this.classList.add("af");});
document.getElementById("port-minus").addEventListener("click",function(){if(PORTIONS>1){PORTIONS--;document.getElementById("port-num").textContent=PORTIONS;renderMeals();renderGrocery();}});
document.getElementById("port-plus").addEventListener("click",function(){if(PORTIONS<10){PORTIONS++;document.getElementById("port-num").textContent=PORTIONS;renderMeals();renderGrocery();}});
document.querySelectorAll(".mtt").forEach(function(btn){btn.addEventListener("click",function(){mealTypeFilter=btn.getAttribute("data-t");document.querySelectorAll(".mtt").forEach(function(b){b.classList.remove("on");});btn.classList.add("on");renderMeals();});});
document.getElementById("m-close").addEventListener("click",closeModal);
document.getElementById("modal").addEventListener("click",function(e){if(e.target===document.getElementById("modal"))closeModal();});
document.addEventListener("keydown",function(e){if(!document.getElementById("modal").classList.contains("open"))return;var gp=document.getElementById("gp-g48");if(!gp||gp.style.display==="none")return;var map={"ArrowLeft":"left","ArrowRight":"right","ArrowUp":"up","ArrowDown":"down"};if(map[e.key]){e.preventDefault();move48(map[e.key]);}});

function spawnNotes(){if(!playing)return;var chars=["\u266a","\u266b","\u266c","\u266d"];var note=document.createElement("div");note.className="note";note.textContent=chars[Math.floor(Math.random()*chars.length)];note.style.left=(15+Math.random()*70)+"%";note.style.top=(50+Math.random()*30)+"vh";document.body.appendChild(note);setTimeout(function(){if(note.parentNode)note.parentNode.removeChild(note);},4000);setTimeout(spawnNotes,2200);}

renderMeals();renderOverview();renderChooser();renderGrocery();
</script>
</body>
</html>
