function fmtQty(qty,p){var v=qty*p;if(v===Math.floor(v))return v;var fr=[[0.25,"\u00bc"],[0.5,"\u00bd"],[0.75,"\u00be"],[0.33,"\u2153"],[0.67,"\u2154"]];var w=Math.floor(v),f=v-w;for(var i=0;i<fr.length;i++)if(Math.abs(f-fr[i][0])<0.08)return(w?w+" ":"")+fr[i][1];return Math.round(v*10)/10;}

