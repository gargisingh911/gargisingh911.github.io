var sqStep=0;
function buildSundayQuiz(){
  var sq=document.getElementById("sunday-quiz");if(!sq)return;
  sq.innerHTML='<div class="sq-card"><h3>It\'s Sunday. What\'s the vibe?</h3><div class="sq-opts">'+
    ["Cheat meal, I deserve it","Surprise me with something to cook","Let me choose the experiment"].map(function(o){return'<button class="sqopt" data-v="'+o+'">'+o+'</button>';}).join("")+
    '</div></div>';
  sq.querySelectorAll(".sqopt").forEach(function(btn){
    btn.addEventListener("click",function(){
      var v=btn.getAttribute("data-v");
      var exps=ALL_MEALS.filter(function(m){return m.type==="experiment";});
      var cheat=ALL_MEALS.filter(function(m){return m.type==="cheat";})[0];
      if(v==="Cheat meal, I deserve it")showSundayResult(ALL_MEALS.indexOf(cheat));
      else if(v==="Surprise me with something to cook")showSundayResult(ALL_MEALS.indexOf(exps[Math.floor(Math.random()*exps.length)]));
      else buildSundayChoose();
    });
  });
}
function buildSundayChoose(){
  var sq=document.getElementById("sunday-quiz");
  var exps=ALL_MEALS.filter(function(m){return m.type==="experiment";});
  sq.innerHTML='<div class="sq-card"><h3>Which experiment?</h3><div class="sq-opts">'+exps.map(function(m){return'<button class="sqopt" data-idx="'+ALL_MEALS.indexOf(m)+'">'+m.name+' \u2014 <span style="font-size:11px;font-style:normal;color:var(--muted)">'+m.time+'</span></button>';}).join("")+'</div></div>';
  sq.querySelectorAll(".sqopt").forEach(function(btn){btn.addEventListener("click",function(){showSundayResult(parseInt(btn.getAttribute("data-idx")));});});
}
function showSundayResult(idx){
  var m=ALL_MEALS[idx];
  var sq=document.getElementById("sunday-quiz");
  sq.innerHTML='<div class="sq-card"><div class="sq-result"><h4>'+(m.type==="cheat"?"Tonight: "+m.name:"Let\'s cook: "+m.name)+'</h4><p style="margin-bottom:10px;font-style:italic">'+m.desc+'</p><button class="tbtn pri" id="sq-open">See recipe &#8594;</button></div><button class="sq-back" id="sq-back">&#8592; Change answer</button></div>';
  document.getElementById("sq-open").addEventListener("click",function(){openModal(idx);});
  document.getElementById("sq-back").addEventListener("click",function(){sqStep=0;buildSundayQuiz();});
}

var currentDay=0;
function showDay(idx){
  currentDay=idx;
  document.querySelectorAll(".nday").forEach(function(b,i){b.classList.toggle("active",i===idx);});
  document.getElementById("day-name").textContent=days[idx].name;
  document.getElementById("day-vibe").textContent=days[idx].vibe;
  var mg=document.getElementById("meals-grid"),sq=document.getElementById("sunday-quiz"),cc=document.getElementById("chooser-card");
  if(idx===6){mg.style.display="none";sq.style.display="block";if(cc)cc.style.display="none";buildSundayQuiz();}
  else{mg.style.display="";sq.style.display="none";if(cc)cc.style.display="block";renderMeals();cAns={};cIdx=0;cDone=false;cFree=false;renderChooser();}
  document.querySelectorAll(".ovc").forEach(function(c,i){c.classList.toggle("active",i===idx);});
}

