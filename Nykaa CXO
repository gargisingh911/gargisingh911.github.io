<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gargi Singh — Strategy & Operations</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --pink:#D4537E;--pink-deep:#993556;--pink-light:#FBEAF0;--pink-pale:#FDF2F6;
  --ink:#1a1a1a;--ink-mid:#444;--ink-muted:#888;
  --border:#F0D6E3;--white:#fff;--bg:#FDF7F9;
}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--ink);font-size:16px;line-height:1.6}
nav{position:sticky;top:0;background:rgba(253,247,249,0.96);backdrop-filter:blur(8px);border-bottom:1px solid var(--border);z-index:100;padding:0 2rem}
.nav-inner{max-width:1040px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:56px}
.nav-logo{font-size:15px;font-weight:700;color:var(--ink);text-decoration:none;letter-spacing:-.3px}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{font-size:13px;color:var(--ink-muted);text-decoration:none;font-weight:500}
.nav-links a:hover{color:var(--pink)}
.nav-cta{background:var(--pink);color:#fff!important;padding:7px 18px;border-radius:999px;font-size:13px!important;font-weight:600!important}
.wrap{max-width:1040px;margin:0 auto;padding:0 2rem}
.hero{background:var(--pink);overflow:hidden;position:relative}
.hero-inner{max-width:1040px;margin:0 auto;padding:4rem 2rem 0;display:grid;grid-template-columns:1fr 380px;gap:3rem;align-items:end}
.hero-left{padding-bottom:4rem}
.hero-kicker{display:inline-block;background:rgba(255,255,255,0.2);color:#fff;font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:5px 14px;border-radius:999px;margin-bottom:1.5rem}
.hero h1{font-size:clamp(44px,7vw,80px);font-weight:900;line-height:.95;letter-spacing:-2.5px;color:#fff;margin-bottom:1.5rem}
.hero h1 .outline{-webkit-text-stroke:2px #fff;color:transparent}
.hero-pitch{background:rgba(255,255,255,0.12);border-left:3px solid rgba(255,255,255,0.5);padding:1rem 1.25rem;border-radius:0 8px 8px 0;margin-bottom:2rem}
.hero-pitch p{font-size:15px;color:rgba(255,255,255,0.9);line-height:1.7}
.hero-actions{display:flex;gap:10px;flex-wrap:wrap}
.btn-white{background:#fff;color:var(--pink);padding:11px 22px;border-radius:999px;font-size:14px;font-weight:700;text-decoration:none;display:inline-block}
.btn-outline{background:transparent;color:#fff;padding:11px 22px;border-radius:999px;font-size:14px;font-weight:600;text-decoration:none;display:inline-block;border:2px solid rgba(255,255,255,0.5)}
.hero-right{display:flex;flex-direction:column;justify-content:flex-end;gap:0}
.stat-block{padding:1.25rem 1.5rem;border-top:1px solid rgba(255,255,255,0.2)}
.stat-block:first-child{border-top:none}
.stat-num{font-size:42px;font-weight:900;color:#fff;line-height:1;letter-spacing:-1.5px}
.stat-num sub{font-size:20px;font-weight:600;vertical-align:baseline}
.stat-label{font-size:12px;color:rgba(255,255,255,0.6);margin-top:2px;line-height:1.3}
.ticker{background:var(--ink);padding:.7rem 0;overflow:hidden;white-space:nowrap}
.ticker-track{display:inline-block;animation:scroll 22s linear infinite}
.ticker-track span{font-size:12px;font-weight:600;color:rgba(255,255,255,0.6);letter-spacing:.06em;text-transform:uppercase;margin:0 2.5rem}
.ticker-track span b{color:var(--pink);font-weight:800}
@keyframes scroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
section{padding:5rem 0;border-bottom:1px solid var(--border)}
.sec-eyebrow{font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--pink);margin-bottom:.6rem}
.sec-title{font-size:clamp(28px,4vw,40px);font-weight:900;letter-spacing:-1px;line-height:1.1;color:var(--ink);margin-bottom:.75rem}
.sec-intro{font-size:15px;color:var(--ink-muted);line-height:1.7;margin-bottom:3rem;max-width:560px}
.statement-grid{display:grid;grid-template-columns:2fr 1fr;gap:1px;background:var(--border);border-radius:20px;overflow:hidden;margin-bottom:1px}
.statement-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);border-radius:0 0 20px 20px;overflow:hidden}
.s-cell{background:var(--white);padding:2.5rem}
.s-cell.pink{background:var(--pink);padding:2.5rem}
.s-cell.pale{background:var(--pink-pale)}
.s-num{font-size:72px;font-weight:900;line-height:1;letter-spacing:-3px;color:var(--pink);margin-bottom:.25rem}
.s-cell.pink .s-num{color:rgba(255,255,255,0.25)}
.s-label{font-size:13px;color:var(--ink-muted);font-weight:500;margin-bottom:1rem}
.s-cell.pink .s-label{color:rgba(255,255,255,0.6)}
.s-title{font-size:20px;font-weight:800;color:var(--ink);line-height:1.2;margin-bottom:.5rem}
.s-cell.pink .s-title{color:#fff}
.s-body{font-size:13px;color:var(--ink-muted);line-height:1.7}
.s-cell.pink .s-body{color:rgba(255,255,255,0.7)}
.tag-row{display:flex;flex-wrap:wrap;gap:6px;margin-top:1rem}
.tag{font-size:11px;font-weight:600;padding:4px 12px;border-radius:999px}
.tag-pink{background:var(--pink-light);color:var(--pink-deep)}
.tag-dark{background:var(--ink);color:#fff}
.built-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem}
.built-card{background:var(--white);border:1.5px solid var(--border);border-radius:16px;padding:1.75rem;position:relative;overflow:hidden}
.built-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:var(--pink)}
.built-card.dim::before{background:var(--ink)}
.built-num{font-size:11px;font-weight:700;color:var(--pink);letter-spacing:.08em;text-transform:uppercase;margin-bottom:.75rem}
.built-card.dim .built-num{color:var(--ink-muted)}
.built-title{font-size:16px;font-weight:800;color:var(--ink);line-height:1.3;margin-bottom:.6rem}
.built-body{font-size:13px;color:var(--ink-muted);line-height:1.6}
.built-status{display:inline-block;font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px;margin-top:.75rem}
.status-live{background:#E1F5EE;color:#0F6E56}
.status-building{background:var(--pink-light);color:var(--pink-deep)}
.gg-strip{background:var(--ink);border-radius:20px;overflow:hidden;margin:3rem 0 0}
.gg-top{padding:2rem 2.5rem 1.5rem;border-bottom:1px solid rgba(255,255,255,0.08)}
.gg-eyebrow{font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--pink);margin-bottom:.4rem}
.gg-headline{font-size:22px;font-weight:900;color:#fff}
.gg-grid{display:grid;grid-template-columns:repeat(4,1fr)}
.gg-cell{padding:1.75rem 2rem;border-right:1px solid rgba(255,255,255,0.08)}
.gg-cell:last-child{border-right:none}
.gg-verb{font-size:24px;font-weight:900;color:#fff;line-height:1;margin-bottom:.4rem}
.gg-desc{font-size:12px;color:rgba(255,255,255,0.4);line-height:1.5}
.parallel{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);border-radius:20px;overflow:hidden;margin-bottom:1.5rem}
.par-cell{background:var(--white);padding:2rem}
.par-cell.dark{background:var(--ink)}
.par-label{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:.75rem;color:var(--pink)}
.par-title{font-size:16px;font-weight:800;color:var(--ink);margin-bottom:.4rem;line-height:1.3}
.par-cell.dark .par-title{color:#fff}
.par-body{font-size:13px;color:var(--ink-muted);line-height:1.7}
.par-cell.dark .par-body{color:rgba(255,255,255,0.55)}
.tl{position:relative}
.tl::before{content:'';position:absolute;left:92px;top:8px;bottom:0;width:2px;background:var(--border)}
.tl-item{display:grid;grid-template-columns:76px 1fr;gap:0 2rem;margin-bottom:0}
.tl-date{font-size:11px;color:var(--ink-muted);font-weight:600;padding-top:4px;text-align:right;line-height:1.4}
.tl-right{padding:0 0 2.5rem 2rem;position:relative}
.tl-right::before{content:'';position:absolute;left:-1px;top:7px;width:10px;height:10px;border-radius:50%;background:var(--pink);border:2px solid var(--bg)}
.tl-role{font-size:16px;font-weight:800;color:var(--ink);margin-bottom:2px}
.tl-org{font-size:13px;color:var(--pink);font-weight:600;margin-bottom:.5rem}
.tl-body{font-size:13px;color:var(--ink-muted);line-height:1.7}
.tl-tags{display:flex;flex-wrap:wrap;gap:5px;margin-top:.6rem}
.contact-section{background:var(--pink)}
.contact-inner{max-width:1040px;margin:0 auto;padding:5rem 2rem;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
.contact-left .sec-eyebrow{color:rgba(255,255,255,0.6)}
.contact-left .sec-title{color:#fff}
.contact-left p{font-size:15px;color:rgba(255,255,255,0.65);line-height:1.7;margin-top:.75rem}
.contact-cards{display:flex;flex-direction:column;gap:.75rem}
.contact-card{background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.2);border-radius:14px;padding:1.25rem 1.5rem;display:flex;align-items:center;justify-content:space-between}
.c-label{font-size:11px;font-weight:700;color:rgba(255,255,255,0.5);letter-spacing:.08em;text-transform:uppercase;margin-bottom:3px}
.c-val{font-size:15px;font-weight:600;color:#fff}
.c-val a{color:#fff;text-decoration:none}
.c-arrow{font-size:18px;color:rgba(255,255,255,0.4)}
@media(max-width:720px){
  .hero-inner{grid-template-columns:1fr}
  .hero-right{display:grid;grid-template-columns:1fr 1fr;gap:0}
  .statement-grid,.statement-grid-2,.built-grid,.parallel,.contact-inner{grid-template-columns:1fr}
  .gg-grid{grid-template-columns:1fr 1fr}
  .tl::before{left:72px}
  .nav-links{display:none}
}
</style>
</head>
<body>
<nav>
  <div class="nav-inner">
    <a class="nav-logo" href="#">Gargi Singh</a>
